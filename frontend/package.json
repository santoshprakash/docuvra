    "@angular/platform-browser": "21.2.14",
    "@angular/router": "21.2.14",
    "pdfjs-dist": "5.7.284",
    "rxjs": "~7.8.0",
    "tslib": "^2.8.1",
    "zone.js": "0.16.2"
  },
  "devDependencies": {
    "@angular/build": "21.2.12",
    "@angular/cli": "21.2.12",
    "@angular/compiler-cli": "21.2.14",
    "@playwright/test": "^1.60.0",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.5.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
